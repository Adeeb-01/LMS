    "features": [
      {
        "name": "User Authentication",
        "description": "Complete authentication system with login, registration, and role-based access control using NextAuth v5. Supports JWT sessions with 30-day expiry, rate limiting, and status-based access.",
        "files": [
          "auth.js",
          "auth.config.js",
          "middleware.js",
          "app/api/auth/[...nextauth]/route.js",
          "app/api/register/route.js",
          "app/login/page.jsx",
          "app/register/page.jsx"
        ],
        "api_doc": {
          "openapi": "3.0.0",
          "paths": {
            "/api/auth/signin": {
              "post": {
                "summary": "User login",
                "tags": [
                  "Authentication"
                ],
                "requestBody": {
                  "required": true,
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "email": {
                            "type": "string",
                            "format": "email"
                          },
                          "password": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                },
                "responses": {
                  "200": {
                    "description": "Login successful"
                  },
                  "401": {
                    "description": "Invalid credentials"
                  },
                  "429": {
                    "description": "Too many login attempts"
                  }
                }
              }
            },
            "/api/register": {
              "post": {
                "summary": "User registration",
                "tags": [
                  "Authentication"
                ],
                "requestBody": {
                  "required": true,
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "required": [
                          "firstName",
                          "lastName",
                          "email",
                          "password"
                        ],
                        "properties": {
                          "firstName": {
                            "type": "string"
                          },
                          "lastName": {
                            "type": "string"
                          },
                          "email": {
                            "type": "string",
                            "format": "email"
                          },
                          "password": {
                            "type": "string",
                            "minLength": 8
                          },
                          "confirmPassword": {
                            "type": "string"
                          },
                          "userRole": {
                            "type": "string",
                            "enum": [
                              "student",
                              "instructor"
                            ]
                          }
                        }
                      }
                    }
                  }
                },
                "responses": {
                  "201": {
                    "description": "Account created successfully"
                  },
                  "400": {
                    "description": "Validation error"
                  },
                  "409": {
                    "description": "Email already exists"
                  }
                }
              }
            }
          }
        }
