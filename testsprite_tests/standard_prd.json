{
  "meta": {
    "project": "Learning Management System (LMS)",
    "date": "2026-01-21",
    "prepared_by": "Software Development Manager"
  },
  "product_overview": "A modern, scalable Learning Management System (LMS) designed for educational institutions and online platforms, enabling course creation, student enrollment, interactive quizzes, progress tracking, and certificate generation with role-based access controls and comprehensive dashboards.",
  "core_goals": [
    "Enable instructors to create, manage, and publish courses with modular lessons and multimedia content.",
    "Provide students with an intuitive interface for course enrollment, lesson consumption, and progress tracking.",
    "Support various user roles (Admin, Instructor, Student) with secure authentication and authorization.",
    "Implement comprehensive quiz capabilities with auto-grading, time limits, and result management.",
    "Automate certification generation upon course completion with validation and rate limiting.",
    "Enable mock payment integration for demo and testing, with a scalable architecture for real payment gateway integration.",
    "Deliver admin and instructor dashboards for user, course, enrollment, and analytics management."
  ],
  "key_features": [
    "Complete user authentication with registration, login, JWT sessions, and role-based access control.",
    "Course management including full CRUD operations, categorization, pricing, thumbnails, and module organization.",
    "Module and lesson management supporting video uploads, lesson ordering, publishing control, and lesson progress tracking.",
    "Robust quiz system with multiple question types, randomized questions, auto-grading, attempt limits, and pass percentage thresholds.",
    "Student enrollment workflows supporting free and paid courses with MockPay simulation for payments.",
    "Progress tracking of lessons and modules including watch time recording and completion reports.",
    "Automatic PDF certificate generation conditional on course completion and quiz success.",
    "Video streaming with HTTP Range support for seeking and playback of locally hosted or external videos.",
    "Admin dashboard covering users, courses, enrollments, payments, reviews, analytics, and bulk operations.",
    "User profile management with editable details, password changes, and avatar uploads.",
    "Course reviews and testimonials submission and admin moderation capabilities.",
    "Category management for course organization with CRUD capabilities.",
    "File upload system handling images, videos, and documents with validation and rate limiting.",
    "Public course catalog with search, filtering, and course detail previews.",
    "Instructor dashboard offering course and enrollment management alongside progress insights.",
    "Strong authorization and permission system preventing unauthorized access and IDOR attacks."
  ],
  "user_flow_summary": [
    "User registers or logs in with email and password, selecting role (student or instructor).",
    "Instructors create and manage courses, modules, and lessons including media uploads and curriculum setup.",
    "Students browse courses, enroll in free or paid courses using MockPay, and access lesson content with progress tracking.",
    "Students take quizzes with enforced time limits and automatic grading; results determine course progression.",
    "On course completion and quiz passing, students request and download PDF completion certificates.",
    "Admins manage users, courses, enrollments, payments, categories, and reviews via the admin dashboard.",
    "Users update profile settings including avatar upload and password management.",
    "Video content is streamed with seeking support to enrolled students through the lesson player interface."
  ],
  "validation_criteria": [
    "User authentication flows enforce role-based access and session expiry as per specifications.",
    "Course, module, lesson CRUD operations validate input and enforce ownership/permission checks.",
    "File uploads conform to size limits, accepted formats, and rate limits with proper error handling.",
    "Payment simulation via MockPay correctly triggers enrollment and payment status updates.",
    "Quiz attempts enforce time limits, max attempts, and randomized question shuffling with correct scoring.",
    "Progress tracking updates accurately reflect lesson watch state and generate valid reports.",
    "Certificate generation only occurs when all criteria are met and respects rate limiting and access controls.",
    "Admin dashboard features include accurate statistics, role/status modifications, and bulk management functions.",
    "Video streaming supports HTTP Range requests delivering full and partial content as expected.",
    "APIs respond with appropriate status codes and error messages for success, validation failures, unauthorized access, and rate limits."
  ],
  "code_summary": {
    "tech_stack": [
      "JavaScript",
      "Next.js 15",
      "React 18",
      "Node.js",
