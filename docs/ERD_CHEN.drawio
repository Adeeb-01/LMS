<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36" version="29.3.4">
  <diagram name="Page-1" id="hv976bF2KOVmRg95wvJx">
    <mxGraphModel dx="2037" dy="1077" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml LMS_Class_Diagram\n!theme plain\nskinparam packageStyle rectangle\nskinparam classAttributeIconSize 0\nskinparam linetype ortho\nskinparam dpi 160\nskinparam shadowing false\n\nleft to right direction\n\ntitle LMS - Complete UML Class Diagram (Organized)\n\n&#39; ============================================\n&#39; PACKAGE: Models (Domain Layer)\n&#39; ============================================\npackage \&quot;Models\&quot; &lt;&lt;Model&gt;&gt; {\n\n  together {\n    class User &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +email: String {unique}\n      +firstName: String\n      +lastName: String\n      +password: String\n      +role: String\n      +createdAt: Date\n      +updatedAt: Date\n    }\n\n    class Student &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +userId: ObjectId\n      +enrollments: ObjectId[]\n    }\n\n    class Instructor &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +userId: ObjectId\n      +courses: ObjectId[]\n    }\n\n    class Admin &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +userId: ObjectId\n    }\n  }\n\n  together {\n    class Category &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +title: String\n      +description: String\n      +thumbnail: String\n    }\n\n    class Course &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +title: String\n      +subtitle: String\n      +description: String\n      +thumbnail: String\n      +modules: ObjectId[]\n      +price: Number\n      +categoryId: ObjectId\n      +instructorId: ObjectId\n    }\n  }\n\n  together {\n    class Module &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +title: String\n      +courseId: ObjectId\n      +lessons: ObjectId[]\n    }\n\n    class Lesson &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +title: String\n      +content: String\n      +moduleId: ObjectId\n      +videoUrl: String\n    }\n  }\n\n  together {\n    class Enrollment &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +studentId: ObjectId\n      +courseId: ObjectId\n      +enrolledAt: Date\n      +progress: Number\n    }\n\n    class Review &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +studentId: ObjectId\n      +courseId: ObjectId\n      +rating: Number\n      +comment: String\n      +createdAt: Date\n    }\n  }\n\n  together {\n    class Quiz &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +courseId: ObjectId\n      +title: String\n      +questions: ObjectId[]\n    }\n\n    class Question &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +quizId: ObjectId\n      +text: String\n      +options: String[]\n      +correctAnswer: String\n    }\n\n    class Submission &lt;&lt;Model&gt;&gt; {\n      +_id: ObjectId\n      +studentId: ObjectId\n      +quizId: ObjectId\n      +answers: String[]\n      +score: Number\n      +submittedAt: Date\n    }\n  }\n}\n\n&#39; ============================================\n&#39; RELATIONSHIPS (Models)\n&#39; ============================================\nUser \&quot;1\&quot; --&gt; \&quot;0..1\&quot; Student\nUser \&quot;1\&quot; --&gt; \&quot;0..1\&quot; Instructor\nUser \&quot;1\&quot; --&gt; \&quot;0..1\&quot; Admin\n\nCategory \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Course\nInstructor \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Course\n\nCourse \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Module\nModule \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Lesson\n\nStudent \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Enrollment\nCourse  \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Enrollment\n\nStudent \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Review\nCourse  \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Review\n\nCourse \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Quiz\nQuiz   \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Question\nStudent \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Submission\nQuiz    \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Submission\n\n\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="chzP4hj3GH9Sldq55GKR-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1628" width="1940" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
