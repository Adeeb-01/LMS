%% LMS Architecture Diagram (C4-style with Mermaid)
%% Generated for Learning Management System (Next.js + MongoDB)

graph TB
    %% ========================================
    %% External Actors
    %% ========================================
    User["👤 User<br/>(Student/Instructor/Admin)<br/>Browser"]
    
    %% ========================================
    %% Layer 1: Client & Entry Points
    %% ========================================
    subgraph ClientLayer["🌐 Client Layer (Browser)"]
        UI_Public["Public Pages<br/>- Home<br/>- Course Catalog<br/>- Login/Register<br/>- Course Details"]
        UI_Student["Student Area<br/>- My Account<br/>- Enrolled Courses<br/>- Lesson Viewer<br/>- Quiz Taker"]
        UI_Instructor["Instructor Dashboard<br/>- My Courses<br/>- Course Editor<br/>- Quiz Builder<br/>- Enrollments"]
        UI_Admin["Admin Panel<br/>- Users<br/>- Courses<br/>- Categories<br/>- Analytics"]
    end
    
    %% ========================================
    %% Layer 2: Next.js App Router (Server Components)
    %% ========================================
    subgraph NextJsLayer["⚡ Next.js App Router (Server)"]
        direction TB
        
        subgraph Middleware["🛡️ Middleware"]
            MW["middleware.js<br/>- Route protection<br/>- Auth check<br/>- Role-based access<br/>- Status verification"]
        end
        
        subgraph ServerComponents["📄 Server Components"]
            SC_Main["app/(main)/**<br/>- page.js files<br/>- layout.js<br/>- Server Components"]
            SC_Dashboard["app/dashboard/**<br/>- Instructor pages<br/>- Course management"]
            SC_Admin["app/admin/**<br/>- Admin pages<br/>- System management"]
        end
        
        subgraph ServerActions["⚙️ Server Actions"]
            SA_Account["account.js<br/>- Profile updates<br/>- Password change"]
            SA_Course["course.js<br/>- CRUD courses<br/>- Ownership checks"]
            SA_Enrollment["enrollment.js<br/>- Free enrollment<br/>- Validation"]
            SA_Quiz["quizv2.js<br/>- CRUD quizzes<br/>- Start/Submit attempts<br/>- Auto-grading"]
            SA_Lesson["lesson.js<br/>- CRUD lessons<br/>- Reorder"]
            SA_Admin["admin*.js<br/>- User management<br/>- System config"]
        end
        
        subgraph APIRoutes["🔌 API Routes"]
            API_Auth["api/auth/[...nextauth]<br/>NextAuth handler"]
            API_Video["api/videos/[filename]<br/>- Stream video<br/>- Range support<br/>- Access control"]
            API_Upload["api/upload/**<br/>- Image upload<br/>- Video upload<br/>- Validation"]
            API_Certificate["api/certificates/[courseId]<br/>- PDF generation<br/>- Access verification"]
            API_Payment["api/payments/mock/confirm<br/>- Mock payment<br/>- Enrollment creation"]
            API_Watch["api/lesson-watch<br/>- Track progress<br/>- Update reports"]
            API_Quiz["api/quizv2/**<br/>- Attempt details"]
            API_Other["api/register<br/>api/me<br/>api/profile/**"]
        end
    end
    
    %% ========================================
    %% Layer 3: Business Logic & Auth
    %% ========================================
    subgraph BusinessLayer["🧠 Business Logic Layer"]
        direction TB
        
        subgraph AuthSystem["🔐 Authentication & Authorization"]
            NextAuth["NextAuth.js<br/>- JWT sessions<br/>- Credentials provider<br/>- bcrypt verification"]
            AuthLib["lib/authorization.js<br/>- Ownership checks<br/>- IDOR prevention<br/>- assertInstructorOwns*"]
            PermLib["lib/permissions.js<br/>- RBAC definitions<br/>- hasPermission()<br/>- requireAdmin()"]
        end
        
        subgraph SecurityLib["🛡️ Security & Validation"]
            RateLimit["lib/rate-limit.js<br/>- In-memory limiter<br/>- 5-20 req/min"]
            Validation["lib/validations.js<br/>- Zod schemas<br/>- Type-safe validation"]
            ErrorLib["lib/errors.js<br/>- Standard responses<br/>- Error codes<br/>- Sanitization"]
        end
        
        subgraph Utilities["🔧 Utilities"]
            Logger["lib/logger.js<br/>- Action/Route logging"]
            DateLib["lib/date.js"]
            ImageUtils["lib/image-utils.js"]
            CertHelper["lib/certificate-helpers.js<br/>- verifyCertificateAccess"]
        end
    end
    
    %% ========================================
    %% Layer 4: Data Access Layer
    %% ========================================
    subgraph DataAccessLayer["📊 Data Access Layer (Queries)"]
        direction LR
        Q_Users["queries/users.js<br/>- getUserByEmail<br/>- getAllUsers"]
        Q_Courses["queries/courses.js<br/>- getCourseDetails<br/>- getPublishedCourses"]
        Q_Enrollments["queries/enrollments.js<br/>- hasEnrollmentForCourse<br/>- enrollForCourse"]
        Q_Quizzes["queries/quizv2.js<br/>- getQuizWithQuestions<br/>- getInProgressAttempt"]
        Q_Reports["queries/reports.js<br/>- getCourseProgress<br/>- createWatchReport"]
        Q_Other["queries/<br/>- modules.js<br/>- lessons.js<br/>- categories.js<br/>- payments.js<br/>- admin.js"]
    end
    
    %% ========================================
    %% Layer 5: Model Layer (Mongoose)
    %% ========================================
    subgraph ModelLayer["🗂️ Model Layer (Mongoose Schemas)"]
        direction LR
        M_User["User<br/>- email (unique)<br/>- password (select:false)<br/>- role (admin/instructor/student)<br/>- status"]
        M_Course["Course<br/>- title, description<br/>- price, active<br/>- instructor → User<br/>- modules[], category"]
        M_Enrollment["Enrollment<br/>- student → User<br/>- course → Course<br/>- method, status<br/>- Unique(student+course)"]
        M_Quiz["Quiz/Question/Attempt<br/>- quizv2-model<br/>- questionv2-model<br/>- attemptv2-model"]
        M_Progress["Watch/Report<br/>- watch-model<br/>- report-model<br/>- Progress tracking"]
        M_Other["Module, Lesson,<br/>Category, Payment,<br/>Testimonial"]
    end
    
    %% ========================================
    %% Layer 6: Database
    %% ========================================
    subgraph DatabaseLayer["💾 Database Layer"]
        MongoDB[(MongoDB<br/>- Connection pooling<br/>- Cached connection<br/>- service/mongo.js)]
    end
    
    %% ========================================
    %% External Services & Storage
    %% ========================================
    subgraph ExternalServices["🌍 External Services & Storage"]
        FileSystem["📁 File System<br/>uploads/videos/<br/>public/uploads/<br/>(Video & Image files)"]
        PDFLib["📄 PDF Generation<br/>pdf-lib, fontkit<br/>Fonts & Images"]
        MockPay["💳 Mock Payment<br/>(Simulated payment)<br/>No real gateway"]
    end
    
    %% ========================================
    %% User Connections
    %% ========================================
    User -->|HTTP Request| UI_Public
    User -->|HTTP Request| UI_Student
    User -->|HTTP Request| UI_Instructor
    User -->|HTTP Request| UI_Admin
    
    %% ========================================
    %% Client Layer Connections
    %% ========================================
    UI_Public -->|SSR/RSC| SC_Main
    UI_Student -->|SSR/RSC| SC_Main
    UI_Instructor -->|SSR/RSC| SC_Dashboard
    UI_Admin -->|SSR/RSC| SC_Admin
    
    %% ========================================
    %% Middleware Protection
    %% ========================================
    SC_Main -->|Protected by| MW
    SC_Dashboard -->|Protected by| MW
    SC_Admin -->|Protected by| MW
    MW -->|Validates session| NextAuth
    MW -->|Checks role| PermLib
    
    %% ========================================
    %% Server Component Interactions
    %% ========================================
    SC_Main -->|Invokes| SA_Course
    SC_Main -->|Invokes| SA_Enrollment
    SC_Main -->|Invokes| SA_Quiz
    SC_Dashboard -->|Invokes| SA_Course
    SC_Dashboard -->|Invokes| SA_Lesson
    SC_Dashboard -->|Invokes| SA_Quiz
    SC_Admin -->|Invokes| SA_Admin
    
    UI_Public -->|Fetch/POST| API_Auth
    UI_Student -->|Fetch| API_Video
    UI_Student -->|POST| API_Watch
    UI_Student -->|GET| API_Certificate
    UI_Instructor -->|POST| API_Upload
    UI_Student -->|POST| API_Payment
    
    %% ========================================
    %% Server Actions → Business Logic
    %% ========================================
    SA_Account -->|Uses| NextAuth
    SA_Account -->|Validates| Validation
    SA_Account -->|Logs| Logger
    
    SA_Course -->|Auth check| NextAuth
    SA_Course -->|Ownership| AuthLib
    SA_Course -->|Validates| Validation
    SA_Course -->|Rate limit| RateLimit
    SA_Course -->|Queries| Q_Courses
    
    SA_Enrollment -->|Auth check| NextAuth
    SA_Enrollment -->|Rate limit| RateLimit
    SA_Enrollment -->|Validates| Validation
    SA_Enrollment -->|Queries| Q_Enrollments
    SA_Enrollment -->|Queries| Q_Courses
    
    SA_Quiz -->|Auth check| NextAuth
    SA_Quiz -->|Ownership| AuthLib
    SA_Quiz -->|Validates| Validation
    SA_Quiz -->|Queries| Q_Quizzes
    SA_Quiz -->|Updates| Q_Reports
    
    SA_Lesson -->|Auth check| NextAuth
    SA_Lesson -->|Ownership| AuthLib
    SA_Lesson -->|Queries| Q_Other
    
    SA_Admin -->|Requires admin| PermLib
    SA_Admin -->|Auth check| NextAuth
    SA_Admin -->|Validates| Validation
    SA_Admin -->|Queries| Q_Users
    
    %% ========================================
    %% API Routes → Business Logic
    %% ========================================
    API_Auth -->|Handles| NextAuth
    
    API_Video -->|Auth check| NextAuth
    API_Video -->|Enrollment check| Q_Enrollments
    API_Video -->|Streams from| FileSystem
    API_Video -->|Rate limit| RateLimit
    
    API_Upload -->|Auth check| NextAuth
    API_Upload -->|Ownership| AuthLib
    API_Upload -->|Validates| Validation
    API_Upload -->|Rate limit| RateLimit
    API_Upload -->|Saves to| FileSystem
    
    API_Certificate -->|Auth check| NextAuth
    API_Certificate -->|Access check| CertHelper
    API_Certificate -->|Progress check| Q_Reports
    API_Certificate -->|Generates| PDFLib
    API_Certificate -->|Rate limit| RateLimit
    
    API_Payment -->|Auth check| NextAuth
    API_Payment -->|Validates| Validation
    API_Payment -->|Creates| Q_Enrollments
    API_Payment -->|Uses| MockPay
    
    API_Watch -->|Auth check| NextAuth
    API_Watch -->|Enrollment check| Q_Enrollments
    API_Watch -->|Updates| Q_Reports
    API_Watch -->|Validates| Validation
    
    API_Quiz -->|Auth check| NextAuth
    API_Quiz -->|Ownership| AuthLib
    API_Quiz -->|Queries| Q_Quizzes
    
    API_Other -->|Auth check| NextAuth
    API_Other -->|Validates| Validation
    
    %% ========================================
    %% Data Access → Models
    %% ========================================
    Q_Users -->|Reads/Writes| M_User
    Q_Courses -->|Reads/Writes| M_Course
    Q_Courses -->|Populate| M_Other
    Q_Enrollments -->|Reads/Writes| M_Enrollment
    Q_Enrollments -->|References| M_Course
    Q_Enrollments -->|References| M_User
    Q_Quizzes -->|Reads/Writes| M_Quiz
    Q_Reports -->|Reads/Writes| M_Progress
    Q_Other -->|Reads/Writes| M_Other
    
    %% ========================================
    %% Models → Database
    %% ========================================
    M_User -->|Mongoose| MongoDB
    M_Course -->|Mongoose| MongoDB
    M_Enrollment -->|Mongoose| MongoDB
    M_Quiz -->|Mongoose| MongoDB
    M_Progress -->|Mongoose| MongoDB
    M_Other -->|Mongoose| MongoDB
    
    %% ========================================
    %% Auth System Internal
    %% ========================================
    NextAuth -->|Queries| Q_Users
    NextAuth -->|Validates password| M_User
    NextAuth -->|Rate limit| RateLimit
    NextAuth -->|Error handling| ErrorLib
    
    AuthLib -->|Queries| Q_Courses
    AuthLib -->|Reads models| M_Course
    AuthLib -->|Reads models| M_Other
    
    CertHelper -->|Queries| Q_Reports
    CertHelper -->|Queries| Q_Courses
    CertHelper -->|Checks enrollment| Q_Enrollments
    
    %% ========================================
    %% Styling
    %% ========================================
    classDef userStyle fill:#4A90E2,stroke:#2E5C8A,stroke-width:3px,color:#fff
    classDef uiStyle fill:#50C878,stroke:#2E7D4E,stroke-width:2px,color:#fff
    classDef nextStyle fill:#000000,stroke:#333,stroke-width:2px,color:#fff
    classDef actionStyle fill:#FF6B6B,stroke:#C44545,stroke-width:2px,color:#fff
    classDef apiStyle fill:#FFA500,stroke:#CC8400,stroke-width:2px,color:#fff
    classDef authStyle fill:#9B59B6,stroke:#6C3483,stroke-width:2px,color:#fff
    classDef securityStyle fill:#E74C3C,stroke:#A93226,stroke-width:2px,color:#fff
    classDef dataStyle fill:#3498DB,stroke:#2471A3,stroke-width:2px,color:#fff
    classDef modelStyle fill:#1ABC9C,stroke:#148F77,stroke-width:2px,color:#fff
    classDef dbStyle fill:#34495E,stroke:#1C2833,stroke-width:3px,color:#fff
    classDef externalStyle fill:#95A5A6,stroke:#707B7C,stroke-width:2px,color:#fff
    
    class User userStyle
    class UI_Public,UI_Student,UI_Instructor,UI_Admin uiStyle
    class MW,SC_Main,SC_Dashboard,SC_Admin nextStyle
    class SA_Account,SA_Course,SA_Enrollment,SA_Quiz,SA_Lesson,SA_Admin actionStyle
    class API_Auth,API_Video,API_Upload,API_Certificate,API_Payment,API_Watch,API_Quiz,API_Other apiStyle
    class NextAuth,AuthLib,PermLib authStyle
    class RateLimit,Validation,ErrorLib securityStyle
    class Q_Users,Q_Courses,Q_Enrollments,Q_Quizzes,Q_Reports,Q_Other dataStyle
    class M_User,M_Course,M_Enrollment,M_Quiz,M_Progress,M_Other modelStyle
    class MongoDB dbStyle
    class FileSystem,PDFLib,MockPay externalStyle
    
    %% ========================================
    %% Legend
    %% ========================================
    subgraph Legend["📖 Legend"]
        L1["🌐 Blue: User/UI Layer"]
        L2["⚡ Black: Next.js (Server Components/Middleware)"]
        L3["🔴 Red: Server Actions"]
        L4["🟠 Orange: API Routes"]
        L5["🟣 Purple: Auth & Authorization"]
        L6["🔴 Dark Red: Security (Rate Limit/Validation/Errors)"]
        L7["🔵 Light Blue: Data Access (Queries)"]
        L8["🟢 Green: Models (Mongoose)"]
        L9["⚫ Dark: Database (MongoDB)"]
        L10["⚪ Gray: External Services/Storage"]
    end
    
    style Legend fill:#F8F9FA,stroke:#DEE2E6,stroke-width:2px
    style L1 fill:#4A90E2,stroke:#2E5C8A,color:#fff
    style L2 fill:#000000,stroke:#333,color:#fff
    style L3 fill:#FF6B6B,stroke:#C44545,color:#fff
    style L4 fill:#FFA500,stroke:#CC8400,color:#fff
    style L5 fill:#9B59B6,stroke:#6C3483,color:#fff
    style L6 fill:#E74C3C,stroke:#A93226,color:#fff
    style L7 fill:#3498DB,stroke:#2471A3,color:#fff
    style L8 fill:#1ABC9C,stroke:#148F77,color:#fff
    style L9 fill:#34495E,stroke:#1C2833,color:#fff
    style L10 fill:#95A5A6,stroke:#707B7C,color:#fff
